# ──────────────────────────────────────────────────────────────────
# cf-router Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets to source control.
# ──────────────────────────────────────────────────────────────────

# Dashboard port (web UI + REST API). Default: 7070
DASHBOARD_PORT=7070

# Where the server binds. Default: 0.0.0.0
DASHBOARD_HOST=0.0.0.0

# Nginx listen port. Default: 6969
NGINX_PORT=6969

# Project home (where config.yml, mappings/, backups/ live). Default: $HOME/projects/cf-router
CF_ROUTER_HOME=/home/openclaw/projects/cf-router

# ──────────────────────────────────────────────────────────────────
# AUTHENTICATION (REQUIRED)
# ──────────────────────────────────────────────────────────────────
# Both must be set or the server starts in UNAUTHENTICATED dev mode
# (with a warning). Generate strong values for production.
# Example: openssl rand -hex 32
DASHBOARD_PASSWORD=replace-me-with-strong-password
AUTH_TOKEN=replace-me-with-32-byte-hex-token

# Optional: separate username for login (default: admin)
DASHBOARD_USERNAME=admin

# ──────────────────────────────────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────────────────────────────────

# Webhook URL for deployment notifications
# WEBHOOK_URL=https://your-webhook.example.com/cf-router

# CORS origin (default: *)
# CORS_ORIGIN=https://dashboard.example.com

# Backup retention in days (default: 7)
# BACKUP_RETENTION_DAYS=7

# Auto-deploy DNS records when mappings change (default: true)
# AUTO_DEPLOY=true

# Auto-sync to Cloudflare on changes (default: true)
# AUTO_SYNC=true

# Language for UI (en, fr, es, de, pt, ja, id). Default: en
# DEFAULT_LANGUAGE=en

# ──────────────────────────────────────────────────────────────────
# TELEGRAM NOTIFICATIONS (OPTIONAL)
# ──────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_ENABLED=true
