#!/usr/bin/env python3
"""
CF-Router Manager
================
Unified routing for all OpenClaw applications.
Manages three layers: nginx (local), Cloudflare DNS, Cloudflare Tunnel.

Usage:
    cf-router status [--no-cf] [--json]  - Show all apps and their status
    cf-router deploy [--dry-run] [--json] - Push apps.yaml to Cloudflare (DNS + tunnel)
    cf-router sync [--json]              - Drift check between apps.yaml vs DNS vs tunnel
    cf-router add <name> --port PORT [--hostname HOST] [--proxy-host HOST] [--health-check PATH] [--no-tls-verify] [--no-deploy] [--dry-run]
    cf-router remove <name> [--no-deploy] [--dry-run] - Remove from all layers
    cf-router enable <name> [--no-deploy] / disable <name> [--no-deploy] - Toggle app
    cf-router edit <name>                - Interactive field editor
    cf-router dns list|add|remove|check   - Direct DNS management
    cf-router tunnel show|update|diff     - Direct tunnel management
    cf-router generate                   - Generate nginx configs
    cf-router reload                     - Reload nginx with new config
    cf-router discover                   - Discover portless apps
    cf-router daemon / serve             - Metrics server + config watcher
"""

