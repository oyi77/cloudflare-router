    cf = get_cf_client()

    if subcommand == 'list':
        try:
            records = cf.list_dns_records()
            print(f"\nDNS Records ({len(records)} total):")
            for record in records:
                if record['type'] == 'CNAME':
                    print(f"  {record['name']} -> {record['content']} (proxied: {record['proxied']})")
        except CloudflareAPIError as e:
            print(f"Error: {e}")

    elif subcommand == 'add':
        if len(args) < 2:
            print("Usage: cf-router dns add <hostname>")
            sys.exit(1)

        hostname = args[1]
        try:
            cf.create_dns_record(hostname)
            print(f"✓ Created DNS CNAME: {hostname}")
        except CloudflareAPIError as e:
            print(f"✗ Failed to create DNS record: {e}")

    elif subcommand == 'remove':
        if len(args) < 2:
            print("Usage: cf-router dns remove <hostname>")
            sys.exit(1)

        hostname = args[1]
        try:
            records = cf.list_dns_records()
            for record in records:
                if record['type'] == 'CNAME' and record['name'] == hostname:
                    cf.delete_dns_record(record['id'])
                    print(f"✓ Deleted DNS CNAME: {hostname}")
                    return
            print(f"DNS record not found: {hostname}")
        except CloudflareAPIError as e:
            print(f"✗ Failed to delete DNS record: {e}")

    elif subcommand == 'check':
        if len(args) < 2:
            print("Usage: cf-router dns check <hostname>")
            sys.exit(1)

        hostname = args[1]
        try:
            records = cf.list_dns_records()
            for record in records:
                if record['type'] == 'CNAME' and record['name'] == hostname:
                    print(f"✓ DNS record exists: {hostname} -> {record['content']}")
                    return
            print(f"✗ DNS record not found: {hostname}")
        except CloudflareAPIError as e:
            print(f"✗ Error checking DNS: {e}")

    else:
        print(f"Unknown DNS command: {subcommand}")


def cmd_tunnel(args: List[str]) -> None:
    """Direct tunnel management commands."""
    if not args:
        print("Usage: cf-router tunnel show|update|diff")
        sys.exit(1)

    subcommand = args[0]
    cf = get_cf_client()
    apps = load_apps()

    if subcommand == 'show':
        try:
            config = cf.get_tunnel_config()
            ingress = config.get('ingress', [])
            print(f"\nTunnel Configuration ({len(ingress)} rules):")
            for rule in ingress:
                if 'hostname' in rule:
                    print(f"  {rule['hostname']} -> {rule['service']}")
                else:
                    print(f"  catch-all -> {rule['service']}")
        except CloudflareAPIError as e:
            print(f"Error: {e}")

    elif subcommand == 'update':
        try:
            ingress = build_tunnel_ingress(apps, cf.tunnel_id)
            cf.update_tunnel_config(ingress)
            print(f"✓ Updated tunnel config with {len(ingress)-1} ingress rules")
        except CloudflareAPIError as e:
            print(f"✗ Failed to update tunnel: {e}")

    elif subcommand == 'diff':
        try:
            # Get current tunnel config
            config = cf.get_tunnel_config()
            current_ingress = {r['hostname']: r['service'] for r in config.get('ingress', []) if 'hostname' in r}

            # Build expected config
            expected_ingress = {}
            for name, app in apps.items():
                if app.enabled and app.hostname:
                    if app.hostname == "hub.aitradepulse.com":
                        service = f"http://127.0.0.1:9099"
                    else:
                        service = f"http://127.0.0.1:{LISTEN_PORT}"
                    expected_ingress[app.hostname] = service

            print("\nTunnel Config Diff:")

            # Missing in tunnel
            missing = set(expected_ingress.keys()) - set(current_ingress.keys())
            if missing:
                print(f"\nMissing in tunnel ({len(missing)}):")
                for hostname in sorted(missing):
                    print(f"  - {hostname} -> {expected_ingress[hostname]}")

            # Extra in tunnel
            extra = set(current_ingress.keys()) - set(expected_ingress.keys())
            if extra:
                print(f"\nExtra in tunnel ({len(extra)}):")
                for hostname in sorted(extra):
                    print(f"  - {hostname} -> {current_ingress[hostname]}")

            # Different service
            different = []
            for hostname in set(expected_ingress.keys()) & set(current_ingress.keys()):
                if expected_ingress[hostname] != current_ingress[hostname]:
                    different.append(hostname)

            if different:
                print(f"\nDifferent service ({len(different)}):")
                for hostname in sorted(different):
                    print(f"  - {hostname}")
                    print(f"      Expected: {expected_ingress[hostname]}")
                    print(f"      Current:  {current_ingress[hostname]}")

            if not missing and not extra and not different:
                print("  ✓ Tunnel config is in sync with apps.yaml")

        except CloudflareAPIError as e:
            print(f"Error: {e}")

    else:
        print(f"Unknown tunnel command: {subcommand}")


