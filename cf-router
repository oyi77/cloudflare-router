#!/usr/bin/env python3
"""
CF-Router Manager
================
Unified routing for all OpenClaw applications.
Supports three modes: port, socket, portless

Usage:
    cf-router status      - Show all apps and their status
    cf-router generate   - Generate nginx configs
    cf-router reload      - Reload nginx with new config
    cf-router discover    - Discover portless apps
    cf-router add <name>  - Add a new app
    cf-router remove <name> - Remove an app
"""

import os
import sys
import yaml
import socket
import subprocess
import time
import threading
import json
from pathlib import Path
from typing import Dict, List, Optional, Any
from urllib.parse import urlparse

CONFIG_DIR = Path.home() / ".cloudflare-router"
APPS_CONFIG = CONFIG_DIR / "apps.yaml"
NGINX_SITES_DIR = CONFIG_DIR / "nginx" / "sites"
NGINX_MAIN_CONFIG = CONFIG_DIR / "nginx" / "nginx.conf"
NGINX_PROXY_CONFIG = CONFIG_DIR / "nginx" / "proxy.conf"
LISTEN_PORT = 6969

class AppConfig:
    def __init__(self, name: str, config: Dict[str, Any]):
        self.name = name
        self.mode = config.get("mode", "port")
        self.hostname = config.get("hostname")
        self.host = config.get("host", "127.0.0.1")
        self.port = config.get("port")
        self.path = config.get("path")
        self.health_check = config.get("health_check", "/")
        self.enabled = config.get("enabled", True)
        self.no_tls_verify = config.get("no_tls_verify", False)
        self.extra_headers = config.get("extra_headers", [])

    def get_target(self) -> str:
        if self.mode == "socket":
            return f"unix:{self.path}"
        elif self.mode == "port":
            return f"http://{self.host}:{self.port}"
        elif self.mode == "portless":
            return f"http://{self.name}.localhost"
        else:
            raise ValueError(f"Unknown mode: {self.mode}")

    def is_healthy(self) -> bool:
        try:
            target = self.get_target()
            if target.startswith("unix:"):
                return os.path.exists(self.path)
            elif target.startswith("http"):
                import urllib.request
                import urllib.error
                url = target + self.health_check
                req = urllib.request.Request(url, method="GET")
                req.add_header("Host", self.hostname or "localhost")
                with urllib.request.urlopen(req, timeout=2) as resp:
                    return resp.status < 400
        except Exception:
            pass
        return False

def load_apps() -> Dict[str, AppConfig]:
    if not APPS_CONFIG.exists():
        print(f"Error: {APPS_CONFIG} not found")
        sys.exit(1)
    
    with open(APPS_CONFIG) as f:
        data = yaml.safe_load(f)
    
    apps = {}
    for name, config in data.get("apps", {}).items():
        apps[name] = AppConfig(name, config)
    return apps

def generate_nginx_config(apps: Dict[str, AppConfig]) -> None:
    NGINX_SITES_DIR.mkdir(parents=True, exist_ok=True)
    
    config_parts = []
    
    for name, app in apps.items():
        if not app.enabled:
            continue
        
        if app.mode == "port":
            target = f"http://{app.host}:{app.port}"
        elif app.mode == "socket":
            target = f"unix:{app.path}"
        elif app.mode == "portless":
            target = f"http://{name}.localhost"
        else:
            print(f"Skipping {name}: unknown mode {app.mode}")
            continue
        
        config = f'''server {{
    listen {LISTEN_PORT};
    server_name {app.hostname};
'''
        if app.no_tls_verify:
            config += f'''    location / {{
        proxy_pass {target};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host {app.hostname};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_ssl_server_name on;
        proxy_ssl_verify off;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }}
'''
        else:
            config += f'''    location / {{
        proxy_pass {target};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host {app.hostname};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }}
'''
        
        config += f'''
    location /cf-health {{
        return 200 '{{"status":"ok","service":"{name}","domain":"{app.hostname}"}}';
        add_header Content-Type application/json;
    }}
}}
'''
        config_parts.append((app.hostname, config))
    
    config_parts.sort(key=lambda x: x[0])
    
    for hostname, config in config_parts:
        safe_name = hostname.replace(".", "_")
        config_file = NGINX_SITES_DIR / f"cf_{safe_name}.conf"
        with open(config_file, "w") as f:
            f.write(config)
    
    includes = "\n".join([
        f"    include {NGINX_SITES_DIR / f'cf_{hostname.replace('.', '_')}.conf'};"
        for hostname, _ in config_parts
    ])
    
    # Default server block for unmatched subdomains
    default_server = f'''
    server {{
        listen {LISTEN_PORT} default_server;
        server_name _;
        
        location / {{
            return 404 '{{"error":"subdomain_not_found","message":"No service configured for this subdomain","host":"$host","hint":"Add the subdomain to apps.yaml to configure routing"}}';
            add_header Content-Type application/json;
            add_header X-Robots-Tag "noindex, nofollow";
        }}
        
        location /cf-health {{
            return 200 '{{"status":"ok","service":"cf-router-default","message":"Default catch-all is active"}}';
            add_header Content-Type application/json;
        }}
    }}
'''
    
    main_config = f'''events {{ worker_connections 1024; }}
http {{
    sendfile on; tcp_nopush on; tcp_nodelay on; keepalive_timeout 65;
    access_log /var/log/nginx/cloudflare-router-access.log;
    error_log /var/log/nginx/cloudflare-router-error.log;
    gzip on; gzip_vary on; gzip_proxied any; gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml;
    
{includes}
{default_server}
}}
'''
    
    with open(NGINX_MAIN_CONFIG, "w") as f:
        f.write(main_config)
    
    print(f"Generated config for {len(config_parts)} apps")

def reload_nginx() -> bool:
    try:
        subprocess.run(["sudo", "nginx", "-t"], check=True, capture_output=True)
        subprocess.run(["sudo", "nginx", "-s", "reload"], check=True, capture_output=True)
        print("Nginx reloaded successfully")
        return True
    except subprocess.CalledProcessError as e:
        print(f"Error reloading nginx: {e.stderr.decode()}")
        return False

def discover_portless() -> Dict[str, Any]:
    discovered = {}
    portless_ports = []
    
    try:
        import urllib.request
        url = "http://127.0.0.1:1355/__portless__/apps"
        with urllib.request.urlopen(url, timeout=2) as resp:
            data = json.loads(resp.read().decode())
            for app in data.get("apps", []):
                discovered[app["name"]] = app
    except Exception as e:
        pass
    
    return discovered

def show_status(apps: Dict[str, AppConfig]) -> None:
    print(f"\n{'='*60}")
    print(f"CF-Router Status")
    print(f"{'='*60}")
    print(f"{'App':<25} {'Mode':<10} {'Hostname':<35} {'Status':<10}")
    print(f"{'-'*60}")
    
    for name, app in sorted(apps.items()):
        status = "✓ healthy" if app.is_healthy() else "✗ down"
        mode = app.mode
        hostname = app.hostname or "-"
        print(f"{name:<25} {mode:<10} {hostname:<35} {status:<10}")
    
    print(f"{'-'*60}")
    print(f"Total: {len(apps)} apps")

def cmd_status(args: List[str]) -> None:
    apps = load_apps()
    show_status(apps)

def cmd_generate(args: List[str]) -> None:
    apps = load_apps()
    generate_nginx_config(apps)
    print("Config generated")

def cmd_reload(args: List[str]) -> None:
    apps = load_apps()
    generate_nginx_config(apps)
    reload_nginx()

def cmd_discover(args: List[str]) -> None:
    discovered = discover_portless()
    print(f"Discovered portless apps: {discovered}")

def cmd_add(args: List[str]) -> None:
    if len(args) < 2:
        print("Usage: cf-router add <name> <mode> [options]")
        sys.exit(1)
    
    name = args[0]
    mode = args[1] if len(args) > 1 else "port"
    
    apps = load_apps()
    
    if name in apps:
        print(f"App {name} already exists")
        sys.exit(1)
    
    config = {
        "mode": mode,
        "hostname": f"{name}.aitradepulse.com",
        "enabled": True,
    }
    
    if mode == "port":
        config["port"] = int(args[2]) if len(args) > 2 else 8080
    elif mode == "socket":
        config["path"] = f"/tmp/{name}.sock"
    
    apps[name] = config
    
    with open(APPS_CONFIG) as f:
        data = yaml.safe_load(f)
    
    data["apps"][name] = config
    
    with open(APPS_CONFIG, "w") as f:
        yaml.dump(data, f, default_flow_style=False)
    
    print(f"Added app: {name} (mode: {mode})")

def cmd_remove(args: List[str]) -> None:
    if not args:
        print("Usage: cf-router remove <name>")
        sys.exit(1)
    
    name = args[0]
    apps = load_apps()
    
    if name not in apps:
        print(f"App {name} not found")
        sys.exit(1)
    
    with open(APPS_CONFIG) as f:
        data = yaml.safe_load(f)
    
    del data["apps"][name]
    
    with open(APPS_CONFIG, "w") as f:
        yaml.dump(data, f, default_flow_style=False)
    
    print(f"Removed app: {name}")

def cmd_daemon(args: List[str]) -> None:
    """Run as daemon with metrics server and auto-reload on config changes."""
    import http.server
    import functools
    
    port = 9090
    if args and args[0].startswith('--port'):
        port = int(args[0].split('=')[1]) if '=' in args[0] else int(args[1])
    
    # Metrics storage
    metrics = {
        'reload_count': 0,
        'last_reload': None,
        'app_health': {},
        'start_time': time.time()
    }
    
    class MetricsHandler(http.server.BaseHTTPRequestHandler):
        # Suppress default error logging for broken pipes
        def handle_one_request(self):
            try:
                super().handle_one_request()
            except (BrokenPipeError, ConnectionResetError, OSError):
                self.close_connection = True
        
        def do_GET(self):
            parsed = urlparse(self.path)
            path = parsed.path
            if path == '/metrics':
                self.serve_metrics()
            elif path == '/health':
                self.serve_health()
            elif path == '/':
                self.send_response(200)
                self.send_header('Content-Type', 'text/html')
                self.end_headers()
                self.wfile.write(b'<h1>CF-Router Metrics</h1><p><a href="/metrics">Prometheus Metrics</a></p><p><a href="/health">Health Check</a></p>')
            else:
                self.send_error(404)
        
        def serve_metrics(self):
            self.send_response(200)
            self.send_header('Content-Type', 'text/plain; version=0.0.4')
            self.end_headers()
            output = []
            output.append('# HELP cf_router_reloads_total Total nginx reloads')
            output.append('# TYPE cf_router_reloads_total counter')
            output.append(f'cf_router_reloads_total {metrics["reload_count"]}')
            output.append('# HELP cf_router_up 1 if router is running')
            output.append('# TYPE cf_router_up gauge')
            output.append('cf_router_up 1')
            for app_name, health in metrics['app_health'].items():
                output.append(f'cf_router_app_health{{app="{app_name}"}} {1 if health else 0}')
            output.append('# HELP cf_router_uptime_seconds Router uptime')
            output.append('# TYPE cf_router_uptime_seconds gauge')
            output.append(f'cf_router_uptime_seconds {time.time() - metrics["start_time"]}')
            self.wfile.write('\n'.join(output).encode())

        def serve_health(self):
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            apps = load_apps()
            health = {name: app.is_healthy() for name, app in apps.items()}
            self.wfile.write(json.dumps({
                'status': 'ok',
                'apps': health,
                'metrics': {
                    'reload_count': metrics['reload_count'],
                    'last_reload': metrics['last_reload']
                }
            }).encode())

        def log_message(self, format, *args):
            pass  # Suppress access logs
        
        def handle_error(self, request, client_address):
            """Handle errors without crashing - especially broken pipes."""
            exc_type, exc_value, _ = sys.exc_info()
            if exc_type in (BrokenPipeError, ConnectionResetError):
                return  # Silently ignore client disconnections
            super().handle_error(request, client_address)
    
    server = http.server.HTTPServer(('', port), MetricsHandler)
    thread = threading.Thread(target=server.serve_forever)
    thread.daemon = True
    thread.start()
    
    print(f"CF-Router daemon started on port {port}")
    print(f"Metrics available at http://localhost:{port}/metrics")
    print(f"Health check at http://localhost:{port}/health")
    
    # Watch for changes
    last_mtime = 0
    try:
        while True:
            if APPS_CONFIG.exists():
                current_mtime = APPS_CONFIG.stat().st_mtime
                if current_mtime != last_mtime:
                    last_mtime = current_mtime
                    apps = load_apps()
                    generate_nginx_config(apps)
                    if reload_nginx():
                        metrics['reload_count'] += 1
                        metrics['last_reload'] = time.time()
                        print(f"[{time.strftime('%H:%M:%S')}] Config reloaded")
            
            # Update app health metrics
            apps = load_apps()
            for name, app in apps.items():
                metrics['app_health'][name] = app.is_healthy()
            
            time.sleep(5)
    except KeyboardInterrupt:
        print("\nShutting down...")
        server.shutdown()


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    commands = {
        "status": cmd_status,
        "generate": cmd_generate,
        "reload": cmd_reload,
        "discover": cmd_discover,
        "add": cmd_add,
        "remove": cmd_remove,
        "daemon": cmd_daemon,
        "serve": cmd_daemon,
    }
    
    if cmd not in commands:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)
    
    commands[cmd](args)

if __name__ == "__main__":
    import json
    main()
