{
  "name": "@oyi77/cloudflare-router",
  "version": "2.3.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Cloudflare Tunnel + Nginx Reverse Proxy Manager with multi-account support. Manage subdomains, DNS, tunnels, and monitoring from one dashboard.",
  "main": "src/server.js",
  "bin": {
    "cloudflare-router": "src/cli.js",
    "cfr": "src/cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "cli": "node src/cli.js",
    "mcp": "node src/cli.js mcp",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop cloudflare-router",
    "pm2:restart": "pm2 restart cloudflare-router",
    "pm2:logs": "pm2 logs cloudflare-router",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "install-completions": "cp completions/cloudflare-router.bash /etc/bash_completion.d/ && cp completions/cloudflare-router.zsh /usr/share/zsh/site-functions/_cloudflare-router",
    "postinstall": "echo 'Run npm run install-completions for shell autocompletion'"
  },
  "files": [
    "src/",
    "completions/",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cloudflare",
    "tunnel",
    "nginx",
    "reverse-proxy",
    "dns",
    "subdomain",
    "multi-account",
    "dashboard",
    "proxy-manager",
    "wildcard"
  ],
  "author": "oyi77",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oyi77/cloudflare-router.git"
  },
  "homepage": "https://github.com/oyi77/cloudflare-router#readme",
  "bugs": {
    "url": "https://github.com/oyi77/cloudflare-router/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
